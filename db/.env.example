# PostgreSQL connection string for the sensai-org Drizzle database.
# Example (local): DATABASE_URL=postgres://postgres:password@localhost:5432/sensai_org
# Example (Neon):  DATABASE_URL=postgres://user:pass@ep-xxx.us-east-2.aws.neon.tech/sensai_org?sslmode=require
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sensai_org
