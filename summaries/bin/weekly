#!/usr/bin/env bash
# weekly — consolidate a week of sensai-org activity into a datestamped summary.
#
# Rolls up the Mon–Sun ISO week containing the target date: git commits, the
# daily summaries produced that week, research-activity state, and file changes.
#
# Usage:
#   summaries/bin/weekly                # week containing today
#   summaries/bin/weekly --date 2026-07-08
#   summaries/bin/weekly --force        # regenerate even if the file exists
#
# Output: summaries/outputs/weekly/<YYYY-Www>.md  (e.g. 2026-W28), idempotent unless --force
#
# Cron (Mondays 07:20):
#   20 7 * * 1 cd /path/to/sensai-org && summaries/bin/weekly >> ~/.sensai/weekly.log 2>&1

set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_lib.sh
. "$DIR/_lib.sh"
ROOT="$(summary_repo_root)"

FORCE=0; DATE="$(date +%F)"
while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=1 ;;
    --date) DATE="${2:?--date needs a value}"; shift ;;
    --date=*) DATE="${1#*=}" ;;
    -h|--help) sed -n '2,15p' "$0"; exit 0 ;;
    *) echo "weekly: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

# Derive ISO week label + Monday..Sunday of the week containing DATE (BSD date).
U="$(date -j -f '%Y-%m-%d' "$DATE" +%u)"
MON="$(date -j -v-"$((U-1))"d -f '%Y-%m-%d' "$DATE" +%F)"
SUN="$(date -j -v+"$((7-U))"d -f '%Y-%m-%d' "$DATE" +%F)"
WEEK="$(date -j -f '%Y-%m-%d' "$DATE" +%G-W%V)"

OUTDIR="$ROOT/summaries/outputs/weekly"
OUT="$OUTDIR/$WEEK.md"
mkdir -p "$OUTDIR"
if [ -f "$OUT" ] && [ "$FORCE" -eq 0 ]; then
  echo "weekly: $OUT already exists (use --force to regenerate)"
  exit 0
fi

AFTER="$MON 00:00:00"; BEFORE="$SUN 23:59:59"
NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

COMMITS="$(git_commits "$ROOT" "$AFTER" "$BEFORE")"
COMMIT_COUNT="$(printf '%s\n' "$COMMITS" | grep -c '^- ' || true)"
DAILIES="$(ls "$ROOT/summaries/outputs/daily/" 2>/dev/null \
  | awk -v a="$MON" -v b="$SUN" '{d=$0; sub(/\.md$/,"",d)} d>=a && d<=b {print "- [" d "](../daily/" $0 ")"}' || true)"
RES="$(sed -n '/ACTIVITIES:START/,/ACTIVITIES:END/p' "$ROOT/research/ACTIVITY.md" 2>/dev/null | grep -E '^\| \[' || true)"
WIKI_FILES="$(git_files "$ROOT" "$AFTER" "$BEFORE" 'summaries/|research/')"

{
  printf -- '---\n'
  printf 'title: "Weekly Summary — %s (%s to %s)"\n' "$WEEK" "$MON" "$SUN"
  printf 'type: summary\nstatus: verified\n'
  printf 'created: %s\nupdated: %s\n' "$MON" "$SUN"
  printf 'tags: [summary, weekly, activity]\n'
  printf 'generated: %s\n' "$NOW"
  printf -- '---\n\n'
  printf '# Weekly Summary — %s\n\n' "$WEEK"
  printf '_Week of **%s** to **%s**. Auto-generated by `summaries/bin/weekly`; ' "$MON" "$SUN"
  printf 'the Patterns section is for human curation._\n\n'
  printf '**Commits this week:** %s\n\n' "$COMMIT_COUNT"
  section "Daily summaries" "$DAILIES"
  section "Commits" "$COMMITS"
  section "Research activity (current state)" "$RES"
  section "Wiki & research file changes" "$([ -n "$WIKI_FILES" ] && printf '%s' "$WIKI_FILES" | sed 's/^/- `/; s/$/`/')"
  printf '## Patterns & insights\n\n_Curate: themes, wins, blockers, next-week focus._\n\n'
} > "$OUT"

echo "weekly: wrote $OUT"
