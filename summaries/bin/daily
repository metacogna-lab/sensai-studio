#!/usr/bin/env bash
# daily — generate a datestamped daily activity summary for sensai-org.
#
# Captures the day's git commits, operations-log entries, research-activity
# updates, wiki/research file changes, and errors into one published summary.
#
# Usage:
#   summaries/bin/daily                 # summary for today
#   summaries/bin/daily --date 2026-07-08
#   summaries/bin/daily --force         # regenerate even if today's file exists
#
# Output: summaries/outputs/daily/<YYYY-MM-DD>.md   (idempotent unless --force)
#
# Cron (07:10 daily):
#   10 7 * * * cd /path/to/sensai-org && summaries/bin/daily >> ~/.sensai/daily.log 2>&1

set -euo pipefail
DIR="$(cd "$(dirname "$0")" && pwd)"
# shellcheck source=_lib.sh
. "$DIR/_lib.sh"
ROOT="$(summary_repo_root)"

FORCE=0; DATE="$(date +%F)"
while [ $# -gt 0 ]; do
  case "$1" in
    --force) FORCE=1 ;;
    --date) DATE="${2:?--date needs a value}"; shift ;;
    --date=*) DATE="${1#*=}" ;;
    -h|--help) sed -n '2,15p' "$0"; exit 0 ;;
    *) echo "daily: unknown arg: $1" >&2; exit 2 ;;
  esac
  shift
done

OUTDIR="$ROOT/summaries/outputs/daily"
OUT="$OUTDIR/$DATE.md"
mkdir -p "$OUTDIR"
if [ -f "$OUT" ] && [ "$FORCE" -eq 0 ]; then
  echo "daily: $OUT already exists (use --force to regenerate)"
  exit 0
fi

AFTER="$DATE 00:00:00"; BEFORE="$DATE 23:59:59"
NOW="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

COMMITS="$(git_commits "$ROOT" "$AFTER" "$BEFORE")"
OPS="$(extract_md_section "$ROOT/agents/operations.md" "$DATE")"
ERRS="$(extract_md_section "$ROOT/agents/errors.md" "$DATE")"
RES="$(grep -E "\| $DATE \|" "$ROOT/research/ACTIVITY.md" 2>/dev/null || true)"
WIKI_FILES="$(git_files "$ROOT" "$AFTER" "$BEFORE" 'summaries/|research/')"

{
  printf -- '---\n'
  printf 'title: "Daily Summary — %s"\n' "$DATE"
  printf 'type: daily\nstatus: verified\n'
  printf 'created: %s\nupdated: %s\n' "$DATE" "$DATE"
  printf 'tags: [summary, daily, activity]\n'
  printf 'generated: %s\n' "$NOW"
  printf -- '---\n\n'
  printf '# Daily Summary — %s\n\n' "$DATE"
  printf '_Auto-generated by `summaries/bin/daily`. Regenerate with `--force`._\n\n'
  section "Commits" "$COMMITS"
  section "Operations log" "$OPS"
  section "Research activity" "$RES"
  section "Wiki & research file changes" "$([ -n "$WIKI_FILES" ] && printf '%s' "$WIKI_FILES" | sed 's/^/- `/; s/$/`/')"
  section "Errors" "$([ -n "$ERRS" ] && printf '%s' "$ERRS" | grep -v '^\*No errors' || true)"
} > "$OUT"

echo "daily: wrote $OUT"
